{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mlx-agent.dev/schemas/adoption-state.schema.json",
  "title": "MLX Agent resumable adoption state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "phase",
    "status",
    "request",
    "completed_phases",
    "host",
    "discovery",
    "shortlist",
    "evidence",
    "comparisons",
    "recommendations",
    "warnings",
    "errors",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "workflow_id": { "type": "string", "minLength": 1 },
    "phase": {
      "enum": ["inspect", "discover", "shortlist", "verify", "compare", "recommend", "complete"]
    },
    "status": { "enum": ["running", "complete"] },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roles",
        "shortlist_limit",
        "allow_network",
        "offline",
        "refresh",
        "memory_gb",
        "quantization",
        "licenses",
        "include_gated",
        "publishers",
        "runtime",
        "fast"
      ],
      "properties": {
        "roles": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "shortlist_limit": { "type": "integer", "minimum": 1, "maximum": 20 },
        "allow_network": { "type": "boolean" },
        "offline": { "type": "boolean" },
        "refresh": { "type": "boolean" },
        "memory_gb": { "type": ["number", "null"] },
        "quantization": { "type": ["string", "null"] },
        "licenses": { "type": "array", "items": { "type": "string" }, "maxItems": 20 },
        "include_gated": { "type": "boolean" },
        "publishers": { "type": "array", "items": { "type": "string" }, "maxItems": 20 },
        "runtime": { "type": ["string", "null"] },
        "fast": { "type": "boolean" }
      }
    },
    "completed_phases": {
      "type": "array",
      "uniqueItems": true,
      "items": { "enum": ["inspect", "discover", "shortlist", "verify", "compare", "recommend"] }
    },
    "host": { "type": "object" },
    "discovery": { "type": "object" },
    "shortlist": { "type": "array", "maxItems": 100, "items": { "type": "object" } },
    "evidence": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": [
          "repo", "role", "strength", "available_locally", "loads",
          "reasoning_confirmed", "runtime", "note", "details"
        ],
        "properties": {
          "repo": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "strength": {
            "enum": ["runtime_tested", "runtime_inventory", "metadata_only", "heuristic_only"]
          },
          "available_locally": { "type": "boolean" },
          "loads": { "type": ["boolean", "null"] },
          "reasoning_confirmed": { "type": ["boolean", "null"] },
          "runtime": { "type": ["string", "null"] },
          "note": { "type": "string", "maxLength": 300 },
          "details": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "comparisons": { "type": "array", "maxItems": 100, "items": { "type": "object" } },
    "recommendations": { "type": "array", "maxItems": 5, "items": { "type": "object" } },
    "warnings": { "type": "array", "maxItems": 50, "items": { "type": "object" } },
    "errors": { "type": "array", "maxItems": 50, "items": { "type": "object" } },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
