{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mlx-agent.dev/schemas/plugin.schema.json",
  "title": "MLX Agent canonical plugin manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "version",
    "identity",
    "scopes",
    "roles",
    "requirements",
    "safety",
    "capabilities",
    "providers"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "1.1"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "identity": {
      "const": "mlx-agent"
    },
    "scopes": {
      "type": "array",
      "items": {
        "enum": [
          "user",
          "project"
        ]
      },
      "uniqueItems": true,
      "minItems": 2
    },
    "roles": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "membership",
          "recommendation_minimum"
        ],
        "properties": {
          "id": {
            "enum": [
              "general",
              "coding",
              "reasoning",
              "vision",
              "embedding",
              "tool-use"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "membership": {
            "enum": [
              "primary",
              "additional"
            ]
          },
          "recommendation_minimum": {
            "enum": [
              "any",
              "verified"
            ]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "id": {
                  "const": "tool-use"
                }
              }
            },
            "then": {
              "properties": {
                "membership": {
                  "const": "additional"
                },
                "recommendation_minimum": {
                  "const": "verified"
                }
              }
            },
            "else": {
              "properties": {
                "membership": {
                  "const": "primary"
                },
                "recommendation_minimum": {
                  "const": "any"
                }
              }
            }
          }
        ]
      },
      "allOf": [
        {
          "contains": {
            "properties": {
              "id": {
                "const": "general"
              }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": {
              "id": {
                "const": "coding"
              }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": {
              "id": {
                "const": "reasoning"
              }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": {
              "id": {
                "const": "vision"
              }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": {
              "id": {
                "const": "embedding"
              }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": {
              "id": {
                "const": "tool-use"
              }
            }
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python3"
      ],
      "properties": {
        "python3": {
          "const": ">=3.9"
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auto_install_provider_cli",
        "auto_download_model",
        "persist_secrets"
      ],
      "properties": {
        "auto_install_provider_cli": {
          "const": false
        },
        "auto_download_model": {
          "const": false
        },
        "persist_secrets": {
          "const": false
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scout",
        "adopt",
        "wire"
      ],
      "properties": {
        "scout": {
          "$ref": "#/$defs/capability"
        },
        "adopt": {
          "$ref": "#/$defs/capability"
        },
        "wire": {
          "$ref": "#/$defs/capability"
        }
      }
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claude",
        "codex",
        "gemini",
        "opencode",
        "agentskills"
      ],
      "properties": {
        "claude": {
          "$ref": "#/$defs/provider"
        },
        "codex": {
          "$ref": "#/$defs/provider"
        },
        "gemini": {
          "$ref": "#/$defs/provider"
        },
        "opencode": {
          "$ref": "#/$defs/provider"
        },
        "agentskills": {
          "$ref": "#/$defs/provider"
        }
      }
    }
  },
  "$defs": {
    "argument": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "type",
        "required"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "string",
            "integer",
            "number",
            "boolean"
          ]
        },
        "kind": {
          "enum": ["positional", "option"]
        },
        "flag": {
          "type": "string",
          "pattern": "^--[a-z][a-z0-9-]*$"
        },
        "required": {
          "type": "boolean"
        },
        "repeatable": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {"properties": {"kind": {"const": "option"}}},
          "then": {"required": ["flag"]},
          "else": {"not": {"required": ["flag"]}}
        }
      ]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["arguments"],
      "properties": {
        "arguments": {
          "type": "array",
          "items": {"$ref": "#/$defs/argument"}
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "description",
        "actions"
      ],
      "properties": {
        "command": {
          "type": "string",
          "pattern": "^mlx-(scout|adopt|wire)$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "actions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"$ref": "#/$defs/action"},
          "propertyNames": {"pattern": "^[a-z][a-z0-9-]*$"}
        }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "native",
        "capabilities",
        "commands",
        "invocation",
        "minimum_version",
        "last_tested_version",
        "version_probe",
        "install_mode",
        "detect_commands",
        "user_root",
        "project_root",
        "artifacts",
        "config_paths"
      ],
      "properties": {
        "native": {
          "type": "boolean"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "enum": [
              "scout",
              "adopt",
              "wire"
            ]
          },
          "uniqueItems": true,
          "minItems": 3,
          "maxItems": 3
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "invocation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "prefix"],
          "properties": {
            "kind": {"enum": ["command", "skill"]},
            "prefix": {"enum": ["/", "$", ""]}
          },
          "allOf": [
            {
              "if": {"properties": {"kind": {"const": "command"}}},
              "then": {"properties": {"prefix": {"const": "/"}}}
            },
            {
              "if": {"properties": {"kind": {"const": "skill"}}},
              "then": {"properties": {"prefix": {"enum": ["$", ""]}}}
            }
          ]
        },
        "minimum_version": {
          "type": ["string", "null"],
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
        },
        "last_tested_version": {
          "type": ["string", "null"],
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
        },
        "version_probe": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["args", "timeout_seconds"],
              "properties": {
                "args": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 4,
                  "items": {"type": "string", "minLength": 1, "maxLength": 64}
                },
                "timeout_seconds": {"type": "number", "exclusiveMinimum": 0, "maximum": 5}
              }
            }
          ]
        },
        "install_mode": {"enum": ["direct", "staged", "portable"]},
        "detect_commands": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "user_root": {
          "type": "string",
          "minLength": 1
        },
        "project_root": {
          "type": "string",
          "minLength": 1
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "destination"],
            "properties": {
              "source": {"type": "string", "minLength": 1},
              "destination": {"type": "string", "minLength": 1},
              "project_destination": {"type": "string", "minLength": 1},
              "scope": {"enum": ["user", "project"]}
            }
          }
        },
        "config_paths": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"native": {"const": true}}},
          "then": {
            "properties": {
              "commands": {"minItems": 1},
              "detect_commands": {"minItems": 1},
              "minimum_version": {"type": "string"},
              "version_probe": {"type": "object"},
              "install_mode": {"enum": ["direct", "staged"]}
            }
          }
        },
        {
          "if": {"properties": {"native": {"const": false}}},
          "then": {
            "properties": {
              "commands": {"maxItems": 0},
              "detect_commands": {"maxItems": 0},
              "minimum_version": {"type": "null"},
              "last_tested_version": {"type": "null"},
              "version_probe": {"type": "null"},
              "install_mode": {"const": "portable"}
            }
          }
        }
      ]
    }
  }
}
