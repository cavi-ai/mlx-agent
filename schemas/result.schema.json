{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mlx-agent.dev/schemas/result.schema.json",
  "title": "MLX Agent result envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "operation",
    "status",
    "data",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "operation": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "ok",
        "error"
      ]
    },
    "data": {
      "type": "object"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "remediation",
        "retryable"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "remediation": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "error"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "error"
        ]
      },
      "else": {
        "not": {
          "required": [
            "error"
          ]
        }
      }
    }
  ]
}
